# Supabase Configuration
SUPABASE_URL=https://your-supabase-project.supabase.co
DATABASE_URL="postgresql://postgres.your-supabase-project:your-password@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres"
DIRECT_URL="postgresql://postgres.your-supabase-project:your-password@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres"
SUPABASE_JWT_SECRET="your-jwt-secret"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_ANON_KEY="your-anon-key"

NODE_ENV=development
PORT=3000

# Trực quan hóa log trace chi tiết qua console và logs/debug-trace.log
# CHÚ Ý: Chỉ nên bật (DEBUG_TRACE=true) ở môi trường phát triển (dev) hoặc thử nghiệm (staging), không bật ở môi trường vận hành thực tế (production) để tránh ảnh hưởng hiệu năng và rác log.
DEBUG_TRACE=false
